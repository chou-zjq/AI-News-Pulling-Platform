# AI 新闻调取平台 — 环境变量模板
# 复制此文件为 .env 并填入实际的 Key

# === 新闻源 ===
# NewsAPI: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# GitHub: https://github.com/settings/tokens (需要 repo scope)
GITHUB_TOKEN=your_github_token_here

# === LLM 默认 Provider（可选）===
# 如果不设置，可以在 KeyBox 管理面板中配置
DEFAULT_LLM_PROVIDER=deepseek
